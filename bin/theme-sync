#!/usr/bin/env bash
set -e

SCHEME="$HOME/.config/hypr/scheme/current.conf"

WALLPAPER="$(caelestia shell wallpaper get)"

BG=$(grep '^\$background =' "$SCHEME" | cut -d'=' -f2 | tr -d ' ')
FG=$(grep '^\$text =' "$SCHEME" | cut -d'=' -f2 | tr -d ' ')
ACCENT=$(grep '^\$primary =' "$SCHEME" | cut -d'=' -f2 | tr -d ' ')

echo "[*] Wallpaper : $WALLPAPER"
echo "[*] Background: $BG"
echo "[*] Foreground: $FG"
echo "[*] Accent    : $ACCENT"

sudo mkdir -p /boot/limine
sudo cp "$WALLPAPER" /boot/limine/wallpaper.jpg

sudo tee /boot/limine/theme.conf >/dev/null <<EOF
# generated by theme-sync

wallpaper: boot():/limine/wallpaper.jpg
wallpaper_style: stretched
backdrop: $BG
EOF

echo "[✓] Limine theme updated"

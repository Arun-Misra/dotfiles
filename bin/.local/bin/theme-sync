#!/usr/bin/env bash
set -e

SCHEME="$HOME/.config/hypr/scheme/current.conf"

WALLPAPER="$(caelestia shell wallpaper get)"

BG=$(grep '^\$background =' "$SCHEME" | cut -d'=' -f2 | tr -d ' ')
FG=$(grep '^\$text =' "$SCHEME" | cut -d'=' -f2 | tr -d ' ')
ACCENT=$(grep '^\$primary =' "$SCHEME" | cut -d'=' -f2 | tr -d ' ')

echo "[*] Wallpaper : $WALLPAPER"
echo "[*] Background: $BG"
echo "[*] Foreground: $FG"
echo "[*] Accent    : $ACCENT"

mkdir -p "$HOME/dotfiles/system/limine"

cp "$WALLPAPER" \
   "$HOME/dotfiles/system/limine/wallpaper.jpg"

TMP=$(mktemp)
LIMINE_CFG="$HOME/dotfiles/system/limine/limine.conf"

awk \
-v bg="$BG" \
-v fg="$FG" \
-v accent="$ACCENT" '
/^# BEGIN THEME-SYNC$/ {
print "# BEGIN THEME-SYNC"
print "wallpaper: boot():/limine/wallpaper.jpg"
print "wallpaper_style: stretched"
print ""

print "interface_branding: ArunOS"
print "interface_branding_colour: " accent
print ""

print "interface_help_colour: " accent
print ""

print "term_background: CC" bg
print "term_foreground: " fg
print ""

print "backdrop: " bg
print "# END THEME-SYNC"
    skip=1
    next
}

/^# END THEME-SYNC$/ {
    skip=0
    next
}

!skip
' "$LIMINE_CFG" > "$TMP"

mv -f "$TMP" "$LIMINE_CFG"

echo "[✓] Limine config updated"

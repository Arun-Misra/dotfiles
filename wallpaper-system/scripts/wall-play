#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "Usage: wall-play <package.wall>"
    exit 1
fi

PACKAGE="$1"

if [[ ! -d "$PACKAGE" ]]; then
    echo "Package not found: $PACKAGE"
    exit 1
fi

FPS=$(jq -r '.fps' "$PACKAGE/metadata.json")
FRAME_FORMAT=$(jq -r '.frame_format // "jpg"' "$PACKAGE/metadata.json")

TMP_VIDEO=$(mktemp --suffix=.mp4)

echo "[*] Building temporary video..."

ffmpeg \
    -framerate "$FPS" \
    -i "$PACKAGE/frames/%04d.$FRAME_FORMAT" \
    -c:v libx264 \
    -pix_fmt yuv420p \
    "$TMP_VIDEO" \
    -y \
    -loglevel error

echo "[*] Playing animation..."

mpv "$TMP_VIDEO"

rm -f "$TMP_VIDEO"

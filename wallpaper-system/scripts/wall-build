#!/usr/bin/env bash
set -euo pipefail

DURATION_LIMIT=10
VIDEO=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -d|--duration)
            DURATION_LIMIT="$2"
            shift 2
            ;;
        *)
            VIDEO="$1"
            shift
            ;;
    esac
done

if [[ -z "$VIDEO" ]]; then
    echo "Usage: wall-build <video> [-d seconds]"
    exit 1
fi

if (( DURATION_LIMIT < 1 || DURATION_LIMIT > 30 )); then
    echo "Error: duration must be between 1 and 30 seconds"
    exit 1
fi

VIDEO="$(realpath "$VIDEO")"

if [[ ! -f "$VIDEO" ]]; then
    echo "File not found: $VIDEO"
    exit 1
fi

NAME="$(basename "$VIDEO")"
NAME="${NAME%.*}"

PACKAGE="${NAME}.wall"

mkdir -p "$PACKAGE"

mv "$VIDEO" "$PACKAGE/source.mp4"

cat > "$PACKAGE/metadata.json" <<EOF
{
  "type": "animated",
  "theme_source": "preview.jpg",
}
EOF

echo "[*] Generating preview"


DURATION=$(
    ffprobe \
    -v error \
    -show_entries format=duration \
    -of default=noprint_wrappers=1:nokey=1 \
    "$VIDEO"
)

MIDPOINT=$(awk "BEGIN { print $DURATION / 2 }")

ffmpeg \
    -ss "$MIDPOINT" \
    -i "$VIDEO" \
    -frames:v 1 \
    -q:v 2 \
    "$PACKAGE/preview.jpg" \
    -y \
    -loglevel error

echo "[✓] Created $PACKAGE"



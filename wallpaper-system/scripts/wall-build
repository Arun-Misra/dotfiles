#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "Usage: wall-build <video>"
    exit 1
fi

VIDEO="$(realpath "$1")"

if [[ ! -f "$VIDEO" ]]; then
    echo "File not found: $VIDEO"
    exit 1
fi

NAME="$(basename "$VIDEO")"
NAME="${NAME%.*}"

PACKAGE="${NAME}.wall"

mkdir -p "$PACKAGE"

cp "$VIDEO" "$PACKAGE/source.mp4"

cat > "$PACKAGE/metadata.json" <<EOF
{
  "type": "animated",
  "fps": 12,
  "loop": true,
  "theme_source": "preview.jpg"
}
EOF

echo "[*] Generating preview"

ffmpeg \
    -i "$VIDEO" \
    -frames:v 1 \
    -q:v 2 \
    "$PACKAGE/preview.jpg" \
    -y \
    -loglevel error

echo "[✓] Created $PACKAGE"
